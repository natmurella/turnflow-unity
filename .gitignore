# Unity Package .gitignore
# This is for a Unity package repository, not a full Unity project

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE specific files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
.vs/
.vscode/
.idea/
*.DotSettings.user

# Temporary Unity files (shouldn't be in package folder anyway)
*.log
*.tmp

# macOS
*.DS_Store

# Keep everything else including:
# - .meta files (essential for GUID tracking)
# - .asmdef files (assembly definitions)
# - package.json (package manifest)
# - All source code (.cs, .shader, .compute, etc.)
# - Documentation (.md files)
# - Prefabs, ScriptableObjects, scenes (.prefab, .asset, .unity)
